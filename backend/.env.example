# ─── SpendWise API — Environment Variables ───────────────────────────────────
# Copy this file to api/.env and fill in real values before running the server.
# NEVER commit api/.env to git.

# ── Server ──────────────────────────────────────────────────────────────────
PORT=5000

# ── MongoDB ─────────────────────────────────────────────────────────────────
# Get from MongoDB Atlas → Connect → Drivers
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── JWT ─────────────────────────────────────────────────────────────────────
# Must be a strong random string (32+ chars). Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_32_CHAR_STRING
JWT_EXPIRES_IN=7d

# ── Email (Nodemailer) ───────────────────────────────────────────────────────
# For Gmail: use an App Password (not your account password)
# https://support.google.com/accounts/answer/185833
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password
EMAIL_FROM="SpendWise <your-email@gmail.com>"

# ── AI Chatbot ───────────────────────────────────────────────────────────────
# Required for AI Advisor feature. Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── Frontend URL (CORS + Email Links) — Optional ────────────────────────────
# Deployed frontend URL. Defaults to http://localhost:5173.
# FRONTEND_URL=http://localhost:5173

# ── Development Only ─────────────────────────────────────────────────────────
# NOTE: MOCK_OTP is defined here but not yet implemented in code.
# To implement: check `process.env.MOCK_OTP === 'true'` in auth route and skip email send.
MOCK_OTP=false
